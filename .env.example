# ─────────────────────────────────────────
# Misinformation Containment Environment
# Environment Variables — DO NOT COMMIT .env
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# LLM Inference endpoint (OpenAI-compatible)
# Example: https://api.openai.com/v1
API_BASE_URL=https://api.openai.com/v1

# Model to use for inference
# Examples: gpt-4o, gpt-4o-mini, gpt-3.5-turbo
MODEL_NAME=gpt-4o-mini

# HuggingFace token for Space deployment / LLM calls
# Required. Get from: huggingface.co → Settings → Access Tokens
HF_TOKEN=hf_...

# Server port (default 7860 for HuggingFace Spaces)
PORT=7860

# Random seed for reproducible environments
SEED=42
